@page
@model AdamVoiceWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Tạo giọng nói";
}
<div class="page has-sticky-submit voice-page">
  <div id="indexMessageStack">
    @if(!string.IsNullOrWhiteSpace(Model.Success)){<div class="alert ok alert-floating" data-auto-dismiss="2000">@Model.Success</div>}
    @if(!string.IsNullOrWhiteSpace(Model.Error)){<div class="alert err">@Model.Error</div>}
    @if(Model.CurrentBalance <= Model.LowPointWarning){<div class="alert warn">Điểm của bạn sắp hết: <b>@Model.CurrentBalance.ToString("N0") điểm</b>. Nên mua thêm điểm để không bị gián đoạn.</div>}
  </div>

  <form method="post" class="composer-grid" id="voiceForm" onsubmit="return confirmCreateVoice()" data-async-generate="true">
    <div class="voice-inputs-hidden" aria-hidden="true">
      @foreach (var v in Model.Voices)
      {
        <input
          type="radio"
          class="voice-hidden-radio"
          name="VoiceId"
          value="@v.Id"
          data-rate="@v.PointRate"
          data-name="@v.Name"
          data-description="@v.Description"
          data-avatar="@v.AvatarEmoji"
          data-is-custom="@(v.OwnerUserId.HasValue && v.OwnerUserId > 0 ? "true" : "false")"
          @(v.Id == Model.VoiceId ? "checked" : "") />
      }
    </div>

    <section class="card composer-main">
      <div class="composer-mobile-toolbar" aria-label="Thao tác nhanh trên điện thoại">
        <button type="button" class="mobile-quick-btn mobile-quick-menu" onclick="toggleSidebar(true)" aria-label="Mở menu">☰</button>
        <button type="button" class="mobile-quick-btn" data-mobile-panel-button="voice" onclick="toggleMobileComposerPanel('voice')">Giọng nói</button>
        <button type="button" class="mobile-quick-btn" data-mobile-panel-button="history" onclick="toggleMobileComposerPanel('history')" title="Lịch sử gần đây">Lịch sử</button>
        <button type="button" class="mobile-quick-btn fill" onclick="if(confirmCreateVoice()) document.getElementById('voiceForm').requestSubmit();">Tạo giọng</button>
      </div>
      <div class="section-head">
        <div class="section-title">Nhập nội dung cần tạo giọng</div>
        <button type="button" class="text-reset-btn" onclick="clearText()" aria-label="Xóa toàn bộ nội dung">
          <span class="text-reset-icon" aria-hidden="true">×</span>
          <span>Xóa hết</span>
        </button>
      </div>
      <textarea id="Text" class="textarea composer-textarea" asp-for="Text" maxlength="8000" placeholder="Nhập nội dung cần tạo giọng..."></textarea>
      <div class="composer-meta-row">
        <label class="check-row normalize-check">
          <input asp-for="AutoNormalize" type="checkbox" checked />
          <span class="normalize-tooltip-anchor">
            Tự tối ưu văn bản tiếng Việt trước khi tạo giọng
            <span class="normalize-tooltip-bubble">Ví dụ: 40.000đ/kg → 40 nghìn đồng một ki lô gam, ship → giao hàng, 22h → 22 giờ.</span>
          </span>
        </label>
        <label class="enhance-chip" title="AI tự thêm biểu cảm và dùng Eleven v3 để giọng đọc giàu cảm xúc hơn.">
          <input asp-for="EnableEnhance" type="checkbox" />
          <span class="enhance-chip-ui">
            <span class="enhance-chip-badge">V3</span>
            <span>Enhance</span>
          </span>
        </label>
        <div class="meta">Số ký tự: <b id="charCount">0</b> / 8.000 ký tự</div>
      </div>

      <div class="actions compact-actions composer-actions composer-actions-single">
        <button id="mainCreateButton" class="primary" type="submit">🎙️ Tạo giọng nói</button>
      </div>
      <div class="mobile-sticky-submit">
        <div class="sticky-cost">Điểm sẽ trừ <b id="stickyPointCost">0 điểm</b></div>
        <button type="button" data-create-mobile onclick="if(confirmCreateVoice()) document.getElementById('voiceForm').requestSubmit();">Tạo giọng</button>
      </div>
      <div class="note">Lưu ý: hệ thống chỉ trừ điểm khi tạo file mới. Nghe lại file trong lịch sử không trừ điểm.</div>
    </section>

    <aside class="card composer-side" id="composerSidePanel">
      <div class="composer-tabs" role="tablist" aria-label="Bảng điều khiển">
        <button type="button" class="composer-tab active" data-panel-tab="voice" onclick="switchComposerPanel('voice')">Giọng nói</button>
        <button type="button" class="composer-tab" data-panel-tab="history" onclick="switchComposerPanel('history')">Lịch sử gần đây</button>
      </div>

      <div class="composer-panel active" data-panel="voice">
        <div class="selected-voice-card selected-voice-picker-card" id="selectedVoiceCard" role="button" tabindex="0" onclick="openVoicePicker()" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();openVoicePicker();}">
          <div class="selected-voice-avatar" id="selectedVoiceAvatar">🎙️</div>
          <div class="selected-voice-info">
            <b id="selectedVoiceName">Chưa chọn giọng</b>
            <span id="selectedVoiceDescription" class="muted">Hãy mở popup để chọn giọng phù hợp.</span>
            <div class="selected-voice-meta">
              <span class="voice-chip" id="selectedVoiceRate">x1 điểm</span>
              <span class="voice-chip" id="selectedVoiceType">Giọng hệ thống</span>
            </div>
          </div>
        </div>

        <div class="voice-panel-row">
          <div class="section-title">Tùy chỉnh giọng nói</div>
        </div>
        <div class="settings side-settings">
          <div class="setting"><label>Tốc độ đọc <b id="SpeedValue">@Model.Speed</b></label><input id="Speed" asp-for="Speed" type="range" min="0.7" max="1.2" step="0.01" oninput="SpeedValue.textContent=this.value" /></div>
          <div class="setting"><label>Độ ổn định <b id="StabilityValue">@Model.Stability</b></label><input id="Stability" asp-for="Stability" type="range" min="0" max="1" step="0.01" oninput="StabilityValue.textContent=this.value" /></div>
          <div class="setting"><label>Độ giống giọng <b id="SimilarityValue">@Model.Similarity</b></label><input id="Similarity" asp-for="Similarity" type="range" min="0" max="1" step="0.01" oninput="SimilarityValue.textContent=this.value" /></div>
          <div class="setting"><label>Phong cách <b id="StyleValue">@Model.Style</b></label><input id="Style" asp-for="Style" type="range" min="0" max="1" step="0.01" oninput="StyleValue.textContent=this.value" /></div>
        </div>
        <div class="presets side-presets">
          <button type="button" class="preset active" data-preset="normal" onclick="setPreset('normal')">Bình thường</button>
          <button type="button" class="preset" data-preset="funny" onclick="setPreset('funny')">Hài hước</button>
          <button type="button" class="preset" data-preset="ad" onclick="setPreset('ad')">Quảng cáo</button>
          <button type="button" class="preset" data-preset="story" onclick="setPreset('story')">Truyền cảm</button>
          <button type="button" class="preset" data-preset="news" onclick="setPreset('news')">Tin tức</button>
          <button type="button" class="preset" data-preset="trend" onclick="setPreset('trend')">TikTok Trend</button>
        </div>
      </div>

      <div class="composer-panel composer-history-panel" data-panel="history">
        <div class="section-title composer-history-title">
          <span class="composer-history-heading">Lịch sử gần đây</span>
          <a href="/History" class="composer-history-link">Xem tất cả</a>
        </div>
        <div id="recentHistoryList">
          @foreach (var j in Model.RecentJobs)
          {
            <div class="history-item" data-audio-item>
              <button type="button" class="play history-play" data-audio-url="@j.AudioUrl" data-state="idle" onclick="toggleHistoryAudio(this)" aria-label="Phát audio">
                <span class="play-icon">▶</span>
              </button>
              <div class="history-main">
                <b>@(j.Text.Length > 30 ? j.Text[..30] + "..." : j.Text)</b><span class="muted history-subline">@j.VoiceName • @j.CharacterCount ký tự</span>
              </div>
              <div class="history-side">
                <div class="muted history-time">@j.CreatedAt.ToString("dd/MM HH:mm")</div>
                <a class="history-download" href="@j.AudioUrl" download aria-label="Tải MP3">⬇</a>
              </div>
              <div class="history-audio-bar" hidden>
                <span class="history-audio-current">0:00</span>
                <input type="range" class="history-progress" min="0" max="100" step="0.1" value="0" oninput="seekHistoryAudio(this)" aria-label="Tua audio" />
                <span class="history-audio-duration">0:00</span>
              </div>
            </div>
          }
          @if (!Model.RecentJobs.Any())
          {
            <p class="muted history-empty">Chưa có file nào.</p>
          }
        </div>
      </div>
    </aside>
  </form>
  <div class="composer-mobile-sheet-backdrop" id="composerMobileSheetBackdrop" onclick="closeMobileComposerPanel()"></div>

  <div class="voice-modal-backdrop" id="voicePickerModal" hidden>
    <div class="voice-modal" role="dialog" aria-modal="true" aria-labelledby="voicePickerTitle">
      <div class="voice-modal-head">
        <div>
          <h2 id="voicePickerTitle">Chọn giọng nói</h2>
          <p class="muted">Tìm kiếm, nghe thử và chọn giọng phù hợp cho nội dung của bạn.</p>
        </div>
        <button type="button" class="voice-modal-close" onclick="closeVoicePicker()" aria-label="Đóng popup">×</button>
      </div>

      <div class="voice-modal-toolbar">
        <div class="voice-picker-tabs" role="tablist" aria-label="Bộ lọc giọng">
          <button type="button" class="voice-picker-tab active" data-voice-filter="all" onclick="setVoicePickerFilter('all')">Tất cả</button>
          <button type="button" class="voice-picker-tab" data-voice-filter="mine" onclick="setVoicePickerFilter('mine')">Giọng của bạn</button>
          <button type="button" class="voice-picker-tab" data-voice-filter="recent" onclick="setVoicePickerFilter('recent')">Gần đây</button>
        </div>
        <input type="search" class="input voice-search-input" id="voiceSearchInput" placeholder="Tìm theo tên hoặc mô tả giọng..." oninput="filterVoicePickerList()" />
      </div>

      <div class="voice-picker-list" id="voicePickerList">
        @foreach (var v in Model.Voices)
        {
          <div
            class="voice-picker-item"
            data-voice-id="@v.Id"
            data-voice-name="@v.Name"
            data-voice-description="@v.Description"
            data-voice-avatar="@v.AvatarEmoji"
            data-voice-rate="@v.PointRate"
            data-voice-custom="@(v.OwnerUserId.HasValue && v.OwnerUserId > 0 ? "true" : "false")"
            role="button"
            tabindex="0"
            onclick="selectVoiceFromPicker(@v.Id)"
            onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVoiceFromPicker(@v.Id);}">
            <div class="voice-picker-preview">
              <button type="button" class="voice-preview-btn" onclick="event.stopPropagation(); previewVoice(@v.Id, this)" aria-label="Nghe thử giọng @v.Name">▶</button>
            </div>
            <div class="voice-picker-content">
              <div class="voice-picker-title-row">
                <b>@v.Name</b>
                <span class="voice-picker-check" data-voice-check="@v.Id">✓</span>
              </div>
              <p>@v.Description</p>
              <div class="voice-picker-tags">
                <span class="voice-pill">x@v.PointRate điểm</span>
                @if (v.OwnerUserId.HasValue && v.OwnerUserId > 0)
                {
                  <span class="voice-pill custom">Giọng của bạn</span>
                }
                else
                {
                  <span class="voice-pill">Giọng hệ thống</span>
                }
              </div>
            </div>
          </div>
        }
      </div>

      <div class="voice-picker-empty" id="voicePickerEmpty" hidden>Không tìm thấy giọng phù hợp với bộ lọc hiện tại.</div>
    </div>
  </div>

  <div class="confirm-backdrop" id="createVoiceConfirmModal" hidden>
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="createVoiceConfirmTitle">
      <div class="confirm-accent"></div>
      <div class="confirm-icon" aria-hidden="true">🎙️</div>
      <h3 id="createVoiceConfirmTitle">Xác nhận tạo giọng nói</h3>
      <p class="muted confirm-lead">Bạn kiểm tra nhanh trước khi hệ thống tạo file MP3 mới.</p>
      <div class="confirm-stats">
        <div class="confirm-stat">
          <span>Nội dung</span>
          <b id="confirmVoiceChars">0 ký tự</b>
        </div>
        <div class="confirm-stat">
          <span>Giọng đọc</span>
          <b id="confirmVoiceName">Adam</b>
        </div>
        <div class="confirm-stat confirm-stat-strong">
          <span>Điểm sẽ trừ</span>
          <b id="confirmVoicePoints">0 điểm</b>
        </div>
      </div>
      <div class="confirm-note-box">Nghe lại hoặc tải lại file đã tạo sẽ không bị trừ điểm.</div>
      <div class="confirm-actions">
        <button type="button" class="secondary" onclick="closeCreateVoiceConfirm()">Hủy</button>
        <button type="button" class="primary" onclick="acceptCreateVoiceConfirm()">Tạo giọng nói</button>
      </div>
    </div>
  </div>
</div>
