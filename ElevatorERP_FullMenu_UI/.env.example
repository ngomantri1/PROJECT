POSTGRES_DB=elevator_erp
POSTGRES_USER=elevator
POSTGRES_PASSWORD=ChangeThisStrongPassword!
DEMO_DEFAULT_PASSWORD=Demo@123456
ENABLE_DEMO_SEED=true
NEXT_PUBLIC_API_BASE_URL=/api
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local demo paths. On Ubuntu production, replace with /opt/elevator-erp/data/...
POSTGRES_DATA_PATH=./.data/postgres
REDIS_DATA_PATH=./.data/redis
UPLOADS_PATH=./.data/uploads
DATA_PROTECTION_KEYS_PATH=./.data/data-protection-keys
