<Window x:Class="CryptoScanner.Desktop.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Crypto Scanner Desktop V1" Height="820" Width="1450" MinHeight="650" MinWidth="1100"
 Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen">
 <Grid Margin="18">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <DockPanel Grid.Row="0" Margin="0,0,0,14">
   <StackPanel>
    <TextBlock Text="CRYPTO SCANNER" FontSize="28" FontWeight="Bold"/>
    <TextBlock Text="Spot market screening • CoinGecko + Binance" Foreground="{StaticResource Muted}"/>
   </StackPanel>
   <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
   <Button Content="QUÉT THỊ TRƯỜNG" Command="{Binding ScanCommand}"/>
   <Button Content="DỪNG" Command="{Binding CancelCommand}" Background="#D9534F"/>
   <Button Content="XUẤT JSON" Command="{Binding ExportCommand}" Background="#27A36A"/>
    <Button Content="MỞ THƯ MỤC" Command="{Binding OpenExportFolderCommand}" Background="#5B6B84"/>
   </StackPanel>
  </DockPanel>
  <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
   <Border Background="{StaticResource Panel}" CornerRadius="10" Margin="4" Padding="14"><StackPanel><TextBlock Text="BTC REGIME" Foreground="{StaticResource Muted}"/><TextBlock Text="{Binding BtcRegime}" FontSize="22" FontWeight="Bold"/></StackPanel></Border>
   <Border Background="{StaticResource Panel}" CornerRadius="10" Margin="4" Padding="14"><StackPanel><TextBlock Text="COINS SCANNED" Foreground="{StaticResource Muted}"/><TextBlock Text="{Binding ScannedCount}" FontSize="22" FontWeight="Bold"/></StackPanel></Border>
   <Border Background="{StaticResource Panel}" CornerRadius="10" Margin="4" Padding="14"><StackPanel><TextBlock Text="PASSED FILTER" Foreground="{StaticResource Muted}"/><TextBlock Text="{Binding PassedCount}" FontSize="22" FontWeight="Bold"/></StackPanel></Border>
   <Border Background="{StaticResource Panel}" CornerRadius="10" Margin="4" Padding="14"><StackPanel><TextBlock Text="BUY READY" Foreground="{StaticResource Muted}"/><TextBlock Text="{Binding BuyReadyCount}" FontSize="22" FontWeight="Bold"/></StackPanel></Border>
   <Border Background="{StaticResource Panel}" CornerRadius="10" Margin="4" Padding="14"><StackPanel><TextBlock Text="UPDATED" Foreground="{StaticResource Muted}"/><TextBlock Text="{Binding UpdatedAt}" FontSize="16" FontWeight="SemiBold"/></StackPanel></Border>
  </UniformGrid>
  <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="10" Padding="8">
   <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedCoin}" AlternationCount="2">
    <DataGrid.Columns>
     <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="45"/>
     <DataGridTextColumn Header="Coin" Binding="{Binding Symbol}" Width="85"/>
     <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
     <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="75"/>
     <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=N6}" Width="100"/>
     <DataGridTextColumn Header="Market Cap" Binding="{Binding MarketCap, StringFormat=N0}" Width="130"/>
     <DataGridTextColumn Header="Volume 24h" Binding="{Binding TotalVolume, StringFormat=N0}" Width="130"/>
     <DataGridTextColumn Header="Binance Vol" Binding="{Binding BinanceQuoteVolume, StringFormat=N0}" Width="130"/>
     <DataGridTextColumn Header="FDV/MC" Binding="{Binding FdvMcRatio, StringFormat=N2}" Width="85"/>
     <DataGridTextColumn Header="Circ." Binding="{Binding CirculatingRatio, StringFormat=P0}" Width="80"/>
     <DataGridTextColumn Header="RSI H4" Binding="{Binding Rsi4H, StringFormat=N1}" Width="80"/>
     <DataGridTextColumn Header="RSI D1" Binding="{Binding Rsi1D, StringFormat=N1}" Width="80"/>
     <DataGridTextColumn Header="Setup" Binding="{Binding Setup}" Width="130"/>
     <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
     <DataGridTextColumn Header="Data" Binding="{Binding DataQuality, StringFormat=P0}" Width="75"/>
    </DataGrid.Columns>
   </DataGrid>
  </Border>
  <DockPanel Grid.Row="3" Margin="0,12,0,0">
   <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding Progress}" Width="300"/>
   <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Muted}" Margin="14,0,0,0" VerticalAlignment="Center"/>
  </DockPanel>
 </Grid>
</Window>
